# ─── Backend API ──────────────────────────────────────────────────────────────
# Base URL of your Express backend (proxied through Vite in dev)
VITE_API_URL=http://localhost:3001

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Set these on your backend (Passport.js) — NOT exposed to the browser
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=AgentIQ
VITE_APP_VERSION=1.0.0

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to show the AI fallback banner when backend is offline
VITE_SHOW_FALLBACK_BANNER=true
